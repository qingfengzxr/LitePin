PORT=4100
HOST=127.0.0.1

# Optional bearer token expected from backend.
# PIN_SERVICE_TOKEN=

# Kubo API endpoint, kept on localhost or private network.
KUBO_API_URL=http://127.0.0.1:5001
# KUBO_REQUEST_TIMEOUT_MS=1800000

# Local persistent data root.
# DATA_ROOT=./data
# PIN_DB_PATH=./data/pin-service.sqlite
# LOG_DIR=./data/logs
# LOG_FILE=./data/logs/pin-service.log

# Worker settings
# PIN_WORKER_POLL_MS=5000
# PIN_WORKER_CONCURRENCY=1
# PIN_MAX_RETRIES=3
# PIN_BASE_RETRY_MS=15000
# PIN_RUNNING_STALE_MS=3600000
# PIN_MAX_REPO_USAGE_RATIO=0.9
