PORT=4100
HOST=127.0.0.1
API_PREFIX=/api/v1
OPENAPI_TITLE=LitePin API
# OPENAPI_VERSION=0.1.0

# Optional bearer token expected from clients or upstream services.
# PIN_SERVICE_TOKEN=

# Kubo API and gateway endpoints, kept on localhost or private network.
KUBO_API_URL=http://127.0.0.1:5001
KUBO_GATEWAY_URL=http://127.0.0.1:8181
# KUBO_REQUEST_TIMEOUT_MS=1800000

# Local persistent data root.
# DATA_ROOT=./data
# PIN_DB_PATH=./data/pin-service.sqlite
# LOG_DIR=./data/logs
# LOG_FILE=./data/logs/litepin.log
# LOG_LEVEL=info

# Worker settings
# PIN_WORKER_POLL_MS=5000
# PIN_WORKER_CONCURRENCY=1
# PIN_WORKER_IDLE_LOG_MS=600000
# PIN_MAX_RETRIES=3
# PIN_BASE_RETRY_MS=15000
# PIN_RUNNING_STALE_MS=3600000
# PIN_MAX_REPO_USAGE_RATIO=0.9
# PIN_PROVIDE_AFTER_PIN=true
# SHUTDOWN_GRACE_MS=15000
